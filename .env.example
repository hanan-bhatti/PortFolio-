# ─── Database ───────────────────────────────────────────────────
# Connection details for the PostgreSQL database.

# DATABASE_URL
# What it does: Supplies the connection string for database access via Prisma. If incorrect or missing, the backend fails to connect, crashing all data-dependent routes.
# Where to get it: Set up a PostgreSQL instance. If using Neon, copy the connection string from the Neon Console (Dashboard → Connection String). Any standard Postgres-compatible host can be used for self-hosting.
# Required: Yes
DATABASE_URL="postgresql://user:password@localhost:5432/portfolio?sslmode=disable"


# ─── Auth (NextAuth) ────────────────────────────────────────────
# Authentication variables for the Admin panel session management and API security.

# AUTH_SECRET
# What it does: Signs session cookies and tokens. If missing or invalid, NextAuth sessions cannot be verified, preventing access to protected routes.
# Where to get it: Generate a cryptographically secure random key. You can generate one in your terminal by running: openssl rand -base64 32
# Required: Yes
AUTH_SECRET="your-32-byte-base64-random-string-placeholder"

# AUTH_URL
# What it does: Sets the canonical root URL for NextAuth callbacks and redirects. If incorrect, authentication flow redirects will fail in production.
# Where to get it: Set to http://localhost:3000 during local development. In production, set to your domain (e.g., https://yourdomain.com).
# Required: Yes
AUTH_URL="http://localhost:3000"


# ─── Admin Bootstrap ────────────────────────────────────────────
# Admin user credentials for seeding the database or logging in.

# ADMIN_EMAIL
# What it does: The email address for the admin user. If the database is empty (no AdminUser rows), the login route allows dynamic signup, rendering this variable ignored. It acts as an optional seed fallback or indicator.
# Where to get it: Choose any email address you want to use to register or reference for the admin account.
# Required: No — dynamic signup on first visit handles admin registration when the database is empty.
ADMIN_EMAIL="admin@example.com"

# ADMIN_PASSWORD_HASH
# What it does: The bcrypt-hashed password corresponding to ADMIN_EMAIL. Similar to ADMIN_EMAIL, this is ignored if registering via the dynamic signup fallback.
# Where to get it: Generate using a bcrypt utility tool (e.g., via CLI: npx bcrypt-cli hash yourpassword 10).
# Required: No — dynamic signup on first visit handles admin registration when the database is empty.
ADMIN_PASSWORD_HASH="$2b$10$replaceWithRealBcryptHashXXXXXXXXXXXXXXXXXX"


# ─── Email (Resend) ─────────────────────────────────────────────
# Email delivery configuration for contact form alerts and newsletter campaigns.

# RESEND_API_KEY
# What it does: Authenticates with the Resend API. If missing, contact emails won't be sent, and newsletter campaign dispatch will fail. The app degrades gracefully — incoming contact messages are still stored in the database.
# Where to get it: Register at https://resend.com, verify a sending domain, and copy the API key (Dashboard → API Keys).
# Required: No — features sending emails will be disabled.
RESEND_API_KEY="re_12345678_AbCdEfGhIjKlMnOpQrStUvWx"

# CONTACT_EMAIL_TO
# What it does: Defines where visitor contact messages should be forwarded.
# Where to get it: Set to your personal email address where you wish to receive notifications.
# Required: No — email alerts will not be sent.
CONTACT_EMAIL_TO="recipient@example.com"

# CONTACT_EMAIL_FROM
# What it does: The email address that alerts are sent from. Must be matched with a domain verified in Resend.
# Where to get it: Format as "Your Name <sender@yourverifieddomain.com>" or use the Resend default: "onboarding@resend.dev".
# Required: No — email alerts will not be sent.
CONTACT_EMAIL_FROM="Portfolio <onboarding@resend.dev>"

# BLOG_EMAIL_FROM
# What it does: The email address used to dispatch newsletter update campaigns to subscribers. Must match a domain verified in Resend.
# Where to get it: Format as "Portfolio Updates <updates@yourverifieddomain.com>".
# Required: No — newsletter campaign dispatch will be disabled.
BLOG_EMAIL_FROM="Portfolio <updates@yourverifieddomain.com>"


# ─── File Uploads (UploadThing) ─────────────────────────────────
# Direct image upload hosting configuration.

# UPLOADTHING_TOKEN
# What it does: Authenticates client/server image uploads. If missing, photo uploads to the blog, photography gallery, and about-me avatar page will fail.
# Where to get it: Register at https://uploadthing.com, create an app, and copy the unified token under API Keys.
# Required: No — admin CMS image uploading features will be disabled.
UPLOADTHING_TOKEN="60-character-or-longer-uploadthing-api-token"


# ─── Site Config ────────────────────────────────────────────────
# Public domain mapping configuration.

# NEXT_PUBLIC_SITE_URL
# What it does: Supplies the base URL of the website. If incorrect, sitemap URLs, XML metadata structures, and link-shortener targets will point to the wrong destination.
# Where to get it: In local dev, use http://localhost:3000.
# Required: Yes — but localhost:3000 works out of the box for local dev. Must be updated to your real public domain before deploying, since sitemap, OG tags, and the link shortener all depend on this being correct in production.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"


# ─── GitHub Stats ───────────────────────────────────────────────
# Integration with GitHub API to display portfolio statistics.

# GITHUB_TOKEN
# What it does: Authenticates queries to GitHub's GraphQL API to fetch repository counts and contribution histories.
# Where to get it: Go to https://github.com/settings/tokens. Generate a classic token with the minimum required "read:user" scope (which is sufficient to query public profiles and contribution calendar data).
# Required: No — homepage dynamic GitHub statistic counters will fail to load or display error states.
GITHUB_TOKEN="ghp_yourGithubPersonalAccessTokenPlaceholder"


# ─── Analytics / Fingerprinting ─────────────────────────────────
# Security and telemetry config.

# FINGERPRINT_SALT
# What it does: Salts the SHA-256 fingerprint generated from visitor IPs and user-agent strings, preventing reverse engineering of raw IPs.
# Where to get it: Provide any secure, long, random string. Do not use standard dictionary words.
# Required: Yes
FINGERPRINT_SALT="generate-a-long-random-salt-string-for-hash-security"
