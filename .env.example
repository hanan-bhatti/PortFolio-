# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/portfolio"

# NextAuth v5
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# Admin credentials (hash generated with bcrypt, e.g. via `npx bcrypt-cli hash <password> 10`)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD_HASH="$2a$10$replace-with-real-bcrypt-hash"

# Resend (contact form emails)
RESEND_API_KEY="re_xxxxxxxxxxxx"
CONTACT_EMAIL_TO="you@example.com"
CONTACT_EMAIL_FROM="Portfolio <noreply@yourdomain.com>"

# Uploadthing (image uploads)
UPLOADTHING_TOKEN="xxxxxxxxxxxx"

# Public site URL (SEO / OG tags)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
