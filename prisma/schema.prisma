generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id         String   @id @default(cuid())
  title      String
  subtitle   String?
  slug       String   @unique
  excerpt    String
  content    String   @db.Text
  coverImage String?
  tags       String[]
  published  Boolean  @default(false)
  views      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  shortLinks     ShortLink[]
  codeCopyEvents CodeCopyEvent[]
  engagementConfig    PostEngagementConfig?
  emojiReactions      PostEmojiReaction[]
  helpfulVotes        PostHelpfulVote[]
  starRatings         PostStarRating[]
  sectionReactions    PostSectionReaction[]
  endSurveyResponses  PostEndSurveyResponse[]
  notifyRequests      PostNotifyRequest[]
  analyticsEvents     PostAnalyticsEvent[]
  emailCampaigns      EmailCampaign[]
}

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  longDesc    String?  @db.Text
  techStack   String[]
  liveUrl     String?
  githubUrl   String?
  coverImage  String?
  featured    Boolean  @default(false)
  order       Int      @default(0)
  resumeBullets String?  @db.Text
  createdAt   DateTime @default(now())
  shortLinks  ShortLink[]
}

model Skill {
  id       String  @id @default(cuid())
  name     String
  icon     String?
  level    Int
  category String
  order    Int     @default(0)
}

model Experience {
  id          String    @id @default(cuid())
  role        String
  company     String
  location    String?
  startDate   DateTime
  endDate     DateTime?
  current     Boolean   @default(false)
  description String    @db.Text
  order       Int       @default(0)
}

model ContactMessage {
  id          String   @id @default(cuid())
  name        String
  email       String
  subject     String
  message     String   @db.Text
  read        Boolean  @default(false)
  isAdminReply Boolean  @default(false)
  createdAt   DateTime @default(now())
  visitorId   String?
  visitor     Visitor? @relation(fields: [visitorId], references: [id], onDelete: SetNull)
}

model SiteSettings {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
}

model Visitor {
  id          String   @id @default(cuid())
  fingerprint String   @unique  // hash of IP + userAgent
  country     String?
  city        String?
  device      String?  // "mobile" | "desktop" | "tablet"
  browser     String?
  os          String?
  firstSeen   DateTime @default(now())
  lastSeen    DateTime @updatedAt
  visits      Int      @default(1)
  consentType String   @default("essential") // "essential" | "all"
  
  pageViews   PageView[]
  formSubmissions ContactMessage[]
  shortLinkClicks ShortLinkClick[]
  codeCopyEvents CodeCopyEvent[]
}

model PageView {
  id            String   @id @default(cuid())
  visitorId     String
  visitor       Visitor  @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  path          String   // e.g. "/projects/authn"
  referrer      String?  // e.g. "https://google.com"
  duration      Int?     // seconds spent on page
  timestamp     DateTime @default(now())
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  utmContent    String?
  utmTerm       String?
  trafficSource String?
}

model ResumeSettings {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
}

model Education {
  id          String   @id @default(cuid())
  degree      String
  institution String
  field       String?
  startYear   String
  endYear     String?
  current     Boolean  @default(false)
  description String?  @db.Text
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model Certification {
  id        String   @id @default(cuid())
  name      String
  issuer    String
  year      String?
  url       String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model ResumeDownload {
  id             String    @id @default(cuid())
  visitorIp      String?
  // ── Geo (enriched) ──────────────────────────────────
  country        String?
  city           String?
  region         String?   // state / province
  timezone       String?   // e.g. "Asia/Karachi"
  isp            String?   // ISP / Org name
  lat            Float?
  lng            Float?
  // ── Raw UA string ────────────────────────────────────
  userAgent      String?
  // ── Parsed UA (stored at write-time) ─────────────────
  deviceType     String?   // "mobile" | "tablet" | "desktop"
  deviceVendor   String?   // "Apple" | "Samsung" etc.
  deviceModel    String?   // "iPhone" | "SM-G991B" etc.
  browserName    String?
  browserVersion String?
  osName         String?
  osVersion      String?
  cpuArch        String?   // "amd64" | "arm64" etc.
  // ── Verify tracking ──────────────────────────────────
  downloadedAt   DateTime  @default(now())
  verifiedAt     DateTime?
  verifyCount    Int       @default(0)
}

model Photo {
  id          String   @id @default(cuid())
  title       String?
  description String?
  imageUrl    String
  order       Int      @default(0)
  visible     Boolean  @default(true)
  exif_data   Json?    @db.JsonB
  likes       Int      @default(0)
  downloads   Int      @default(0)
  shares      Int      @default(0)
  createdAt   DateTime @default(now())

  interactions PhotoInteraction[]
}

model PhotoInteraction {
  id          String   @id @default(cuid())
  photoId     String
  photo       Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)
  visitorId   String
  type        String   // "like" | "download" | "share"
  createdAt   DateTime @default(now())

  @@index([photoId])
  @@index([visitorId])
}

model AdminUser {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  twoFactorSecret  String?
  twoFactorEnabled Boolean  @default(false)
  resetToken       String?  @unique
  resetTokenExpiry DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  sessions         AdminSession[]
}

model AdminSession {
  id          String   @id @default(cuid())
  userId      String
  user        AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String   @unique
  ipAddress   String?
  userAgent   String?
  deviceType  String?
  browser     String?
  os          String?
  country     String?
  city        String?
  active      Boolean  @default(true)
  lastUsedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
}

model ShortLink {
  id        String   @id @default(cuid())
  code      String   @unique
  targetUrl String
  type      String   // "link" | "share"
  postId    String?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  clicks    ShortLinkClick[]
}

model ShortLinkClick {
  id          String   @id @default(cuid())
  shortLinkId String
  shortLink   ShortLink @relation(fields: [shortLinkId], references: [id], onDelete: Cascade)
  visitorId   String?
  visitor     Visitor?  @relation(fields: [visitorId], references: [id], onDelete: SetNull)
  userAgent   String?
  referer     String?
  createdAt   DateTime @default(now())
}

model CodeCopyEvent {
  id          String   @id @default(cuid())
  postId      String?
  post        Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  codeBlockId String?
  codeBlock   String   @db.Text
  isMultiline Boolean
  visitorId   String?
  visitor     Visitor?  @relation(fields: [visitorId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}

model PostEngagementConfig {
  id                  String   @id @default(cuid())
  postId              String   @unique
  post                Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  emojiReactionsOn     Boolean  @default(false)
  helpfulVoteOn        Boolean  @default(false)
  starRatingOn         Boolean  @default(false)
  sectionReactionsOn   Boolean  @default(false)
  endSurveyOn          Boolean  @default(false)
  difficultyToggleOn   Boolean  @default(false)
  exitIntentOn         Boolean  @default(false)
  notifyMeOn           Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model PostEmojiReaction {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  visitorId String
  emoji     String   // one of: 👍 🔥 🤯 ❤️ 😂 — validate server-side against fixed enum list
  createdAt DateTime @default(now())

  @@unique([postId, visitorId, emoji]) // one of each emoji per visitor per post; visitor can pick multiple distinct emojis but not duplicate the same one
  @@index([postId])
}

model PostHelpfulVote {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  visitorId String
  helpful   Boolean
  createdAt DateTime @default(now())

  @@unique([postId, visitorId]) // one vote per visitor per post, last write wins on update
  @@index([postId])
}

model PostStarRating {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  visitorId String
  rating    Int      // 1-5, validate server-side
  createdAt DateTime @default(now())

  @@unique([postId, visitorId])
  @@index([postId])
}

model PostSectionReaction {
  id         String   @id @default(cuid())
  postId     String
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  visitorId  String
  sectionId  String   // maps to a stable anchor/heading-id generated at publish time from the TipTap content
  emoji      String
  createdAt  DateTime @default(now())

  @@index([postId, sectionId])
}

model PostEndSurveyResponse {
  id          String   @id @default(cuid())
  postId      String
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  visitorId   String
  responseText String? // free text "what should I cover next"
  difficulty  String?  // "too_basic" | "just_right" | "too_advanced"
  createdAt   DateTime @default(now())

  @@index([postId])
}

model PostNotifyRequest {
  id        String   @id @default(cuid())
  postId    String?  // post they were reading when they signed up (null for global newsletter)
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  email     String
  topic     String?  // optional free text on what topic they want notified about
  confirmed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

model PostAnalyticsEvent {
  id          String   @id @default(cuid())
  postId      String
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  visitorId   String
  eventType   String   // "scroll_depth" | "time_on_page" | "copy_event" | "bounce" | "explored" | "exit_intent_shown" | "exit_intent_converted"
  value       String?  // e.g. scroll_depth: "80", time_on_page: seconds as string, copy_event: code-block id
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  createdAt   DateTime @default(now())

  @@index([postId, eventType])
}

model SiteSearchQuery {
  id        String   @id @default(cuid())
  query     String
  visitorId String?
  resultsCount Int
  createdAt DateTime @default(now())

  @@index([query])
}

model EmailCampaign {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  subject   String
  sentCount Int      @default(0)
  createdAt DateTime @default(now())
  
  opens     EmailOpen[]
}

model EmailOpen {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  email       String
  userAgent   String?
  openedAt    DateTime @default(now())
}
